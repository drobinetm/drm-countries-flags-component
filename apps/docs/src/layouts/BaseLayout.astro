---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  canonical?: string
  currentPath?: string
}

const {
  title = '@drobinetm/countries-flags',
  description = 'Accessible country selector component with flag icons for Angular, React and Vue.',
  canonical,
  currentPath = '/',
} = Astro.props

const fullTitle = title === '@drobinetm/countries-flags'
  ? title
  : `${title} — @drobinetm/countries-flags`

const navState = {
  home: currentPath === '/',
  angular: currentPath.startsWith('/docs/angular') || currentPath.startsWith('/demos/angular'),
  react: currentPath.startsWith('/docs/react') || currentPath.startsWith('/demos/react'),
  vue: currentPath.startsWith('/docs/vue') || currentPath.startsWith('/demos/vue'),
  support: currentPath.startsWith('/support'),
}
---

<!doctype html>
    <html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- Topbar -->
    <header class="topbar" id="top">
      <div class="shell topbar__inner">
        <a class="brand" href="/">
          <span class="brand__mark" aria-hidden="true">
            <span class="brand__mark-world"></span>
            <span class="brand__mark-flagpole"></span>
            <span class="brand__mark-wave">
              <span class="brand__mark-wave-stripe brand__mark-wave-stripe--cyan"></span>
              <span class="brand__mark-wave-stripe brand__mark-wave-stripe--emerald"></span>
              <span class="brand__mark-wave-stripe brand__mark-wave-stripe--amber"></span>
            </span>
          </span>
          <span class="brand__text">
            <span class="brand__eyebrow">Open source</span>
            <span class="brand__name">@drobinetm/countries-flags</span>
          </span>
        </a>
        <div class="topbar__actions">
          <nav class="nav" aria-label="Primary">
            <a href="/" aria-current={navState.home ? 'page' : undefined}>Home</a>
            <a href="/docs/angular" data-nav-framework="angular" aria-current={navState.angular ? 'page' : undefined}>Angular</a>
            <a href="/docs/react" data-nav-framework="react" aria-current={navState.react ? 'page' : undefined}>React</a>
            <a href="/docs/vue" data-nav-framework="vue" aria-current={navState.vue ? 'page' : undefined}>Vue</a>
            <a href="/support" aria-current={navState.support ? 'page' : undefined}>Support</a>
          </nav>
          <a
            class="github-button"
            href="https://github.com/drobinetm/drm-countries-flags-component"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="github-button__icon" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.39v-1.37c-2.23.49-2.7-.98-2.7-.98-.36-.95-.9-1.2-.9-1.2-.73-.51.06-.5.06-.5.81.06 1.23.85 1.23.85.71 1.26 1.87.89 2.33.68.07-.53.28-.89.5-1.09-1.78-.21-3.64-.93-3.64-4.12 0-.91.31-1.65.82-2.24-.08-.2-.35-1.04.08-2.15 0 0 .67-.22 2.2.86a7.45 7.45 0 0 1 4 0c1.53-1.08 2.2-.86 2.2-.86.43 1.11.16 1.95.08 2.15.51.59.82 1.33.82 2.24 0 3.2-1.87 3.91-3.65 4.11.29.26.54.75.54 1.52v2.25c0 .22.14.47.55.39A8 8 0 0 0 8 0Z"></path>
              </svg>
            </span>
            <span>GitHub</span>
          </a>
        </div>
      </div>
    </header>

    <!-- Page content -->
    <main>
      <slot />
    </main>

    <script>
      import '../scripts/aos-init.ts'
    </script>

    <script is:inline>
      const syncThemingNav = () => {
        if (!window.location.pathname.startsWith('/docs/theming')) return

        const navLinks = document.querySelectorAll('[data-nav-framework]')
        const framework = window.location.hash.replace('#', '')

        navLinks.forEach((link) => {
          if (!(link instanceof HTMLElement)) return
          link.removeAttribute('aria-current')
          if (framework && link.dataset.navFramework === framework) {
            link.setAttribute('aria-current', 'page')
          }
        })
      }

      syncThemingNav()
      window.addEventListener('hashchange', syncThemingNav)
    </script>

    <script is:inline>
      const setupBackToTop = () => {
        const button = document.querySelector('.back-to-top')
        if (!(button instanceof HTMLElement)) return
        if (button.dataset.bound === 'true') return

        button.dataset.bound = 'true'

        const syncVisibility = () => {
          button.dataset.visible = window.scrollY > 320 ? 'true' : 'false'
        }

        button.addEventListener('click', (event) => {
          event.preventDefault()
          window.scrollTo({ top: 0, behavior: 'smooth' })
          window.history.replaceState(null, '', '#top')
        })

        syncVisibility()
        window.addEventListener('scroll', syncVisibility, { passive: true })
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupBackToTop, { once: true })
      } else {
        setupBackToTop()
      }

      document.addEventListener('astro:page-load', setupBackToTop)
    </script>

    <!-- Footer -->
    <a class="back-to-top" href="#top" aria-label="Back to top" data-visible="false">
      <span class="back-to-top__icon" aria-hidden="true">
        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M10 15V5M10 5L5.75 9.25M10 5L14.25 9.25"
            stroke="currentColor"
            stroke-width="1.9"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
      </span>
    </a>

    <footer class="footer">
      <div class="shell">
        <div class="footer__inner">
          <div class="footer__meta">
            <p class="footer__title">@drobinetm/countries-flags</p>
            <p class="footer__description">
              Country selector components for Angular, React, and Vue.
            </p>
            <p class="footer__copyright">&copy; {new Date().getFullYear()} Diovi Robinet Morales</p>
          </div>

          <div class="footer__links" aria-label="Project links">
            <a
              href="/docs/angular"
            >Docs</a>
            <span aria-hidden="true">&middot;</span>
            <a
              href="/support"
            >Support</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
