---
import { Code } from 'astro:components'

interface Props {
  code: string
  ariaLabel?: string
  lang?: string
}

const { code, ariaLabel = 'Copy code', lang = 'ts' } = Astro.props
const blockId = `copy-block-${Math.random().toString(36).slice(2, 10)}`
---

<div class="copy-code" data-copy-code>
  <button
    class="copy-code__button"
    type="button"
    aria-label={ariaLabel}
    data-copy-trigger
    data-copy-target={blockId}
  >
    <span class="copy-code__icon" aria-hidden="true">
      <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M5.333 5.333V3.867c0-.747 0-1.12.145-1.405a1.333 1.333 0 0 1 .583-.583c.285-.145.658-.145 1.405-.145h4.667c.746 0 1.12 0 1.404.145.251.128.455.332.583.583.147.285.147.658.147 1.405v4.666c0 .747 0 1.12-.147 1.405a1.333 1.333 0 0 1-.583.583c-.284.145-.658.145-1.404.145h-1.467" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M3.867 14.267c-.747 0-1.12 0-1.405-.145a1.333 1.333 0 0 1-.583-.583c-.145-.285-.145-.658-.145-1.405V7.467c0-.747 0-1.12.145-1.405.128-.251.332-.455.583-.583.285-.145.658-.145 1.405-.145h4.666c.747 0 1.12 0 1.405.145.251.128.455.332.583.583.145.285.145.658.145 1.405v4.667c0 .747 0 1.12-.145 1.405a1.333 1.333 0 0 1-.583.583c-.285.145-.658.145-1.405.145H3.867Z" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
    <span data-copy-text>Copy</span>
  </button>

  <div class="copy-code__pre" id={blockId}>
    <Code code={code} lang={lang} theme="github-dark" />
  </div>
  <span class="copy-code__toast" role="status" aria-live="polite" data-copy-toast>
    <span class="copy-code__toast-icon" aria-hidden="true">✓</span>
    <span>Copied</span>
  </span>
</div>

<script is:inline>
  (() => {
    const root = document.currentScript?.previousElementSibling
    if (!(root instanceof HTMLElement)) return

    const trigger = root.querySelector('[data-copy-trigger]')
    const toast = root.querySelector('[data-copy-toast]')
    const text = root.querySelector('[data-copy-text]')

    if (!(trigger instanceof HTMLButtonElement)) return

    trigger.addEventListener('click', async () => {
      const targetId = trigger.dataset.copyTarget
      const target = targetId ? document.getElementById(targetId) : null
      const value = target?.innerText ?? target?.textContent ?? ''

      try {
        await navigator.clipboard.writeText(value)
      } catch {
        const selection = window.getSelection()
        const range = document.createRange()

        if (!target || !selection) return

        selection.removeAllRanges()
        range.selectNodeContents(target)
        selection.addRange(range)
        document.execCommand('copy')
        selection.removeAllRanges()
      }

      root.dataset.copied = 'true'
      if (text) text.textContent = 'Copied'
      window.setTimeout(() => {
        root.dataset.copied = 'false'
        if (text) text.textContent = 'Copy'
      }, 1800)
    })
  })()
</script>

<style>
  .copy-code {
    position: relative;
  }

  .copy-code__button {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2.35rem;
    padding: 0.55rem 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    background: rgba(8, 16, 31, 0.92);
    color: rgba(245, 248, 255, 0.96);
    font: inherit;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .copy-code__button:hover {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(13, 24, 43, 0.96);
  }

  .copy-code__button:focus-visible {
    outline: 2px solid var(--cyan);
    outline-offset: 3px;
  }

  .copy-code__icon {
    width: 1rem;
    height: 1rem;
    display: inline-flex;
  }

  .copy-code__icon svg {
    width: 100%;
    height: 100%;
  }

  .copy-code__pre {
    padding-top: 4.25rem;
  }

  .copy-code__pre :global(pre) {
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .copy-code__toast {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.8rem;
    padding: 0.7rem 1rem;
    border-radius: 16px;
    border: 1px solid rgba(98, 211, 147, 0.38);
    background: rgba(7, 24, 26, 0.96);
    color: #6be29d;
    font-size: 0.95rem;
    font-weight: 700;
    opacity: 0;
    transform: translateY(-6px) scale(0.96);
    pointer-events: none;
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .copy-code__toast-icon {
    width: 1.3rem;
    height: 1.3rem;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    border: 1px solid rgba(98, 211, 147, 0.35);
    background: rgba(15, 45, 35, 0.92);
    font-size: 0.85rem;
  }

  .copy-code[data-copied='true'] .copy-code__button {
    opacity: 0;
  }

  .copy-code[data-copied='true'] .copy-code__toast {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @media (max-width: 640px) {
    .copy-code__button,
    .copy-code__toast {
      right: 0.8rem;
      top: 0.8rem;
    }

    .copy-code__pre {
      padding-top: 4.6rem;
    }
  }
</style>
