{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "src",
  "projects": {
    "eval-angular-countries-flags": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/eval-angular-countries-flags",
            "browser": "src/main.ts",
            "index": "src/index.html",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "allowedCommonJsDependencies": ["country-list", "aos"],
            "assets": [
              {
                "glob": "**/*",
                "input": "../../node_modules/flag-icons",
                "output": "flag-icons"
              }
            ],
            "styles": ["src/styles.css"]
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "eval-angular-countries-flags:build"
          }
        }
      }
    }
  }
}
