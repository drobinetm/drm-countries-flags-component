{
  "name": "@drobinetm/react-countries-flags",
  "version": "1.0.0",
  "description": "React 18+ component to display a country selector with flag icons",
  "author": "Diovi Robinet",
  "license": "MIT",
  "keywords": [
    "react",
    "countries",
    "flags",
    "select",
    "dropdown",
    "iso",
    "hooks",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/drobinetm/drm-countries-flags-component",
    "directory": "packages/react"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "default": "./dist/react-countries-flags.css"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist && cp src/styles.d.ts dist/styles.d.ts",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "flag-icons": ">=7.0.0"
  },
  "dependencies": {
    "@drobinetm/countries-flags-core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.5",
    "vite": "8.0.5",
    "vite-plugin-dts": "^3.9.1"
  }
}
