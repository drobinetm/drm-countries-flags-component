{
  "name": "@drobinetm/angular-countries-flags",
  "version": "1.0.1",
  "description": "Angular 17+ standalone component to display a country selector with flag icons",
  "author": "Diovi Robinet",
  "license": "MIT",
  "keywords": [
    "angular",
    "countries",
    "flags",
    "select",
    "dropdown",
    "iso",
    "standalone",
    "signal"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/drobinetm/drm-countries-flags-component",
    "directory": "packages/angular"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/fesm2022/drobinetm-angular-countries-flags.mjs",
  "module": "./dist/fesm2022/drobinetm-angular-countries-flags.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/fesm2022/drobinetm-angular-countries-flags.mjs",
      "default": "./dist/fesm2022/drobinetm-angular-countries-flags.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json && node ./scripts/postbuild.mjs",
    "dev": "ng-packagr -p ng-package.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "@angular/forms": ">=17.0.0",
    "flag-icons": ">=7.0.0"
  },
  "dependencies": {
    "@drobinetm/countries-flags-core": "workspace:*"
  },
  "devDependencies": {
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "ng-packagr": "^19.0.0",
    "tslib": "^2.8.1",
    "typescript": "~5.6.0"
  }
}
